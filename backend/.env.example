# Voice & Video Studio AI — Backend configuration
# Copy to .env and adjust to your setup

# Optional: path to external storage (SSD, NAS, etc.)
# Audio files, AI models and XTTS speakers will be stored here.
# If not set, defaults to ./audio-output, ./ai-models, ./xtts-speakers
# VOICE_STUDIO_DATA_DIR=/mnt/my-drive

# Optional: password protection (bcrypt hash stored in memory on startup)
# VOICE_STUDIO_PASSWORD=

# Optional: bind address and port (default: 0.0.0.0:47821)
# HOST=0.0.0.0
# PORT=47821

# ── AI Video Orchestrator ─────────────────────────────────────────────────────

# Ollama host for PromptProcessor (DirectorPass + StoryboardPass)
# OLLAMA_HOST=http://localhost:11434

# Override the Ollama model used for video prompt generation
# VA_PROMPT_MODEL=qwen2.5:7b-instruct-q4_K_M

# Host shown to the browser for the in-app VNC bootstrap window.
# Set to the IP/hostname your browser can reach this machine on.
# VA_NOVNC_HOST=localhost

# Optional: Pixverse REST API key (alternative to browser session)
# Get one at https://app.pixverse.ai/openapi
# PIXVERSE_API_KEY=
